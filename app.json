{
  "expo": {
    "name": "Pro Match",
    "slug": "pro-match",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-notifications",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Pro Match uses your location to show you people nearby."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Pro Match to access your photos so you can upload profile pictures.",
        "NSLocationWhenInUseUsageDescription": "Pro Match uses your location to show you people nearby."
      }
    },
    "android": {
      "package": "com.promatch.app",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "INTERNET",
        "READ_MEDIA_IMAGES",
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {},
    "extra": {
      "eas": {
        "projectId": "680d32b3-a5e2-4527-a864-117d7c83deaa"
      }
    }
  }
}
