{
  "expo": {
    "name": "Wovnn",
    "slug": "pro-match",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "updates": {
      "url": "https://u.expo.dev/680d32b3-a5e2-4527-a864-117d7c83deaa"
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-notifications",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Wovnn uses your location to show you people nearby."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Wovnn to access your photos so you can upload profile pictures.",
        "NSLocationWhenInUseUsageDescription": "Wovnn uses your location to show you people nearby."
      }
    },
    "android": {
      "package": "com.promatch.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0B14"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "INTERNET",
        "READ_MEDIA_IMAGES",
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {},
    "extra": {
      "eas": {
        "projectId": "680d32b3-a5e2-4527-a864-117d7c83deaa"
      }
    }
  }
}
