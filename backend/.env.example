PORT=4000
JWT_SECRET=super-secret-change-me
# Local: mongodb://127.0.0.1:27017/promatch  |  Atlas: mongodb+srv://user:pass@cluster.mongodb.net/promatch
MONGODB_URI=mongodb://127.0.0.1:27017/promatch
# Dev mode: OTP is fixed to 123456, returned in the API response, no real SMS sent.
# Set to false in production AFTER wiring a real SMS provider in src/utils/sms.js
AUTH_DEV_MODE=true
# Public base URL used to build image URLs returned by the upload endpoint.
# Android emulator must use 10.0.2.2 (not localhost) to reach your machine.
PUBLIC_BASE_URL=http://10.0.2.2:4000
# Billing: leave Razorpay keys blank to run in stub mode (no real payments;
# /billing/dev/grant test-grants entitlements). Set keys + run `npm i razorpay`
# and BILLING_DEV_MODE=false to go live.
BILLING_DEV_MODE=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Google sign-in: the Web OAuth client ID (public — it ships in the app too).
# /auth/google verifies Google ID tokens against this. Blank = endpoint returns 503.
GOOGLE_WEB_CLIENT_ID=
